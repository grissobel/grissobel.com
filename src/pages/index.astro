---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/seal.png" />
    <meta name="viewport" content="width=device-width" />
    <title>grissobel</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400&display=swap" rel="stylesheet" />
    <script is:inline src="https://code.iconify.design/3/3.1.1/iconify.min.js"></script>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background: #fff;
        font-family: 'Cormorant Garamond', serif;
        color: #2a2d3a;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      main {
        text-align: center;
        width: 90%;
        max-width: 500px;
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 4rem 0;
      }

      a.logo {
        text-decoration: none;
        color: #2a2d3a;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      a.logo img {
        width: 100px;
        margin-bottom: 2rem;
      }

      hr {
        border: none;
        border-top: 1px solid #c8cad4;
        margin: 2rem 0;
      }

      h1 {
        font-size: 2.6rem;
        font-weight: 300;
        letter-spacing: 0.4em;
      }

      nav {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      nav a {
        font-size: 1.1rem;
        letter-spacing: 0.25em;
        text-decoration: none;
        color: #2a2d3a;
        text-transform: lowercase;
      }

      nav a:hover {
        opacity: 0.6;
      }

      .divider-vertical {
        width: 1px;
        background-color: #c8cad4;
        margin: 2rem auto 0 auto;
        flex: 1;
        min-height: 60px;
      }

      footer {
        width: 90%;
        max-width: 500px;
        padding: 2rem 0;
        font-size: 1rem;
        letter-spacing: 0.1em;
        color: #2a2d3a;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      footer p {
        margin: 0;
      }

      .icons {
        display: flex;
        gap: 1rem;
        justify-content: flex-end;
        align-items: center;
      }

      .icons a {
        text-decoration: none;
        color: #2a2d3a;
        font-size: 1.6rem;
        display: flex;
        align-items: center;
      }

      .icons a:hover {
        opacity: 0.6;
      }
    </style>
  </head>
  <body>
    <main>
      <a href="/" class="logo">
        <img src="/seal.png" alt="seal illustration" />
      </a>

      <hr />

      <h1>grissobel</h1>

      <hr />

      <nav>
        <a href="https://grissobel.substack.com" target="_blank">substack</a>
        <a href="/engineering">engineering</a>
        <a href="/about">about</a>
      </nav>

      <div class="divider-vertical"></div>
    </main>

    <footer>
      <p>© 2026 grissobel</p>
      <div class="icons">
        <a href="/search" aria-label="search"><span class="iconify" data-icon="mdi:magnify"></span></a>
        <a href="https://grissobel.substack.com" target="_blank" aria-label="substack"><span class="iconify" data-icon="simple-icons:substack"></span></a>
        <a href="https://instagram.com/grissobel" target="_blank" aria-label="instagram"><span class="iconify" data-icon="mdi:instagram"></span></a>
        <a href="https://github.com/grissobel" target="_blank" aria-label="github"><span class="iconify" data-icon="mdi:github"></span></a>
        <a href="https://goodreads.com/grissobel" target="_blank" aria-label="goodreads"><span class="iconify" data-icon="simple-icons:goodreads"></span></a>
        <a href="https://linkedin.com/grissobel" target="_blank" aria-label="linkedin"><span class="iconify" data-icon="mdi:linkedin"></span></a>
      </div>
    </footer>
  </body>
</html>